{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-standard-scss"
  ],
  "plugins": [
    "stylelint-scss"
  ],
  "rules": {
    "selector-class-pattern": "^[a-z][a-zA-Z0-9]*$|^[a-z][a-z0-9-]*[a-z0-9]$",
    "custom-property-pattern": "^[a-z][a-zA-Z0-9]*$|^[a-z][a-z0-9-]*[a-z0-9]$",
    "keyframes-name-pattern": "^[a-z][a-zA-Z0-9]*$|^[a-z][a-z0-9-]*[a-z0-9]$",
    "scss/at-rule-no-unknown": true,
    "scss/dollar-variable-pattern": "^[a-z][a-zA-Z0-9]*$|^[a-z][a-z0-9-]*[a-z0-9]$",
    "scss/at-mixin-pattern": "^[a-z][a-zA-Z0-9]*$|^[a-z][a-z0-9-]*[a-z0-9]$",
    "no-empty-source": null,
    "color-function-notation": "legacy",
    "alpha-value-notation": "number"
  },
  "ignoreFiles": [
    "node_modules/**/*",
    "dist/**/*",
    "build/**/*",
    "coverage/**/*"
  ]
}
